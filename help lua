function help()
  print(ifColor(bcyn, "\nUsage of " .. arg[0] .. ":\n", rst))
  print(ifColor(orng, "--hash <hashstring>", rst) .. " :\n\t" .. ifColor(grn, "Analyze a single hash string", rst))
  print(ifColor(orng, "--color", rst)..ifColor(grn, " or ", rst)..ifColor(orng, "-c", rst).. " :\n\t" .. ifColor(grn, "Enable colored output", rst))
  print(ifColor(orng, "--verbose", rst) .. " :\n\t" .. ifColor(grn, "Show detailed results per hash", rst))
  print(ifColor(orng, "--help", rst)..ifColor(grn, " or ", rst)..ifColor(orng, "-h", rst).. " :\n\t" .. ifColor(grn, "Show this help message", rst))
  print(ifColor(orng, "--file </path/to/file>", rst)..ifColor(grn, " or ", rst)..ifColor(orng, "-f </path/to/file", rst).. " :\n\t" .. ifColor(grn, "Analyze hashes from a file", rst))
  print(ifColor(orng, "--version", rst)..ifColor(grn, " or ", rst)..ifColor(orng, "-v", rst).. " :\n\t" .. ifColor(grn, "Show the version of " .. arg[0], rst))
end
